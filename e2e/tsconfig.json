{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "../dist/e2e",
    "rootDir": "..",
    "baseUrl": "..",
    "paths": {
      "@shared/*": ["src/shared/*"]
    },
    "lib": ["ES2020"]
  },
  "include": [
    "./**/*.ts",
    "../src/shared/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
