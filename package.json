{
  "name": "xnat-viewer",
  "version": "0.5.1",
  "description": "XNAT Desktop Workstation with native Cornerstone3D rendering",
  "main": "dist/main/main/index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:main\"",
    "dev:renderer": "vite --port ${VITE_DEV_SERVER_PORT:-5173}",
    "postinstall": "node scripts/fix-dev-app-name.js",
    "dev:main": "node scripts/fix-dev-app-name.js && wait-on http://localhost:${VITE_DEV_SERVER_PORT:-5173} && tsc -p tsconfig.main.json && VITE_DEV_SERVER_URL=http://localhost:${VITE_DEV_SERVER_PORT:-5173} electron .",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "start": "electron .",
    "package": "electron-builder",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:cornerstone": "vitest run src/renderer/lib/cornerstone/__tests__",
    "test:cornerstone:coverage": "vitest run --coverage src/renderer/lib/cornerstone/__tests__"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@cornerstonejs/adapters": "^4.16.1",
    "@cornerstonejs/core": "^4.16.1",
    "@cornerstonejs/dicom-image-loader": "^4.16.1",
    "@cornerstonejs/polymorphic-segmentation": "^4.16.1",
    "@cornerstonejs/tools": "^4.16.1",
    "dicom-parser": "^1.8.21",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^25.2.1",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^2.1.8",
    "autoprefixer": "^10.4.24",
    "concurrently": "^9.2.1",
    "electron": "^40.2.1",
    "electron-builder": "^26.8.1",
    "jsdom": "^25.0.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "vite": "^5.4.21",
    "vitest": "^2.1.8",
    "wait-on": "^9.0.3"
  }
}
